# ── Binance API Credentials ──────────────────────────────────
# Dapatkan di: https://testnet.binancefuture.com (untuk testnet)
#              https://www.binance.com/id/my/settings/api-management (live)

BINANCE_API_KEY=MASUKKAN_API_KEY_KAMU_DISINI
BINANCE_API_SECRET=MASUKKAN_API_SECRET_KAMU_DISINI

# ── Mode ──────────────────────────────────────────────────────
# true  = testnet (aman, uang palsu)
# false = live trading (hati-hati!)
TESTNET=true
